datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Correction {
  id        Int      @id @default(autoincrement())
  videoId   String
  startTime Float
  original  String
  text      String
  author    String
  createdAt DateTime @default(now())
}
