# GitHub OAuth — create an app at https://github.com/settings/developers
# Set the callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# Any random string (used to sign session tokens)
NEXTAUTH_SECRET=change_me_to_any_random_string
NEXTAUTH_URL=http://localhost:3000

# Optional: Whisper AI transcription for videos with no captions
# Get a key at platform.openai.com
OPENAI_API_KEY=
